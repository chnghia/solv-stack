# ==============================================
# SOLV Stack Environment Configuration
# Copy this file to .env and customize as needed
# ==============================================

# --- API Keys ---
# Master key used by all services to authenticate with LiteLLM
LITELLM_MASTER_KEY=sk-solv-stack

# --- GPU Configuration ---
# Comma-separated GPU IDs (e.g., 0,1,2,3)
CUDA_VISIBLE_DEVICES=0,1

# --- vLLM Settings ---
# Number of GPUs for tensor parallelism
TENSOR_PARALLEL_SIZE=2
# Maximum context length
MAX_MODEL_LEN=8192
# GPU memory usage (0.0-1.0)
GPU_MEMORY_UTILIZATION=0.6

# --- Model Configuration ---
# Path to model directory (relative to ./models)
VLLM_MODEL=Qwen2.5-7B-Instruct
# Model name exposed via API
VLLM_MODEL_NAME=qwen2.5-7b

# --- Llama.cpp Settings ---
# Path to GGUF model (relative to ./models)
LLAMA_MODEL=Llama-3-8B-Instruct-Q4_K_M.gguf
# Number of layers to offload to GPU (999 to offload all)
LLAMA_N_GPU_LAYERS=999
# Context size for llama.cpp (tổng cho tất cả parallel slots)
LLAMA_CTX_SIZE=32768
# Number of parallel requests (slots)
LLAMA_PARALLEL=4
# Chat template (auto, gemma2, qwen2, chatml, ...) - Quan trọng cho tool call
LLAMA_CHAT_TEMPLATE=auto
# Specific GPUs for llama-server
LLAMA_CUDA_DEVICES=0

# --- Network & External Access ---
# The public URL of your instance (required for SearXNG links/CSS)
SEARXNG_BASE_URL=http://localhost:8080/search/

# --- Optional: External Fallback API ---
# OPENROUTER_API_KEY=sk-or-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
